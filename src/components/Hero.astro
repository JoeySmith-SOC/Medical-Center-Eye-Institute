---
const {
  eyebrow,
  title,
  copy,
  ctaText = 'Request Appointment',
  ctaHref = '/contact',
  secondaryCtaText,
  secondaryCtaHref,
  mediaEyebrow = 'Demo Image Area',
  mediaTitle = 'Office or provider photography placeholder',
  mediaCopy = 'Use this space for a welcoming clinic image, diagnostic equipment, or a provider portrait once approved by the client.',
} = Astro.props
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
      <h1>{title}</h1>
      <p class="lead">{copy}</p>
      <div class="hero-ctas">
        <a class="btn primary" href={ctaHref}>{ctaText}</a>
        {secondaryCtaText && secondaryCtaHref ? (
          <a class="btn secondary" href={secondaryCtaHref}>{secondaryCtaText}</a>
        ) : null}
      </div>
    </div>
    <aside class="hero-media" aria-label="Featured clinic image placeholder">
      <div class="placeholder-img">
        <p class="placeholder-eyebrow">{mediaEyebrow}</p>
        <h2>{mediaTitle}</h2>
        <p>{mediaCopy}</p>
      </div>
    </aside>
  </div>
</section>
