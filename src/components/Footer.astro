---
import { legalLinks, navigationLinks, siteName, withBase } from '../utils/site'
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <h3>{siteName}</h3>
      <p class="muted">
        Refined ophthalmology care with calm, patient-centered placeholder content prepared for client review.
      </p>
    </div>
    <div>
      <h4>Quick Links</h4>
      <ul class="footer-links">
        {navigationLinks.map((item) => (
          <li><a href={withBase(item.href)}>{item.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h4>Contact</h4>
      <address class="footer-contact">
        <span>
          Placeholder phone: <a href="tel:+10000000000">(000) 000-0000</a>
        </span>
        <span>Placeholder address: 123 Medical Plaza, Suite 200, City, State ZIP</span>
        <span>Placeholder office hours: Monday-Friday, 8:00 AM-5:00 PM</span>
        <span>Final office details pending client confirmation</span>
      </address>
      <ul class="footer-links footer-legal">
        {legalLinks.map((item) => (
          <li><a href={withBase(item.href)}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="container copyright">© {new Date().getFullYear()} {siteName}. Demo content only.</div>
</footer>
