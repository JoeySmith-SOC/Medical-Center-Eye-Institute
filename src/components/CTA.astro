---
const {
  eyebrow,
  title,
  copy,
  ctaText = 'Contact Us',
  ctaHref = '/contact',
} = Astro.props
---
<section class="cta-band">
  <div class="container cta-inner">
    <div>
      {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
      <h3>{title}</h3>
      <p class="muted">{copy}</p>
    </div>
    <div>
      <a class="btn primary large" href={ctaHref}>{ctaText}</a>
    </div>
  </div>
</section>
