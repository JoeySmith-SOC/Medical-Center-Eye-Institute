---
import MainLayout from '../layouts/MainLayout.astro'
import SectionHeader from '../components/SectionHeader.astro'

const pageTitle = 'Privacy Policy'
const pageDescription = 'Privacy policy placeholder — replace with clinic-specific privacy policies.'
---
<MainLayout title={pageTitle} description={pageDescription}>
  <section class="container">
    <SectionHeader title="Privacy Policy" />
    <p class="muted">This privacy policy is a placeholder. Do not publish without legal review. The site does not collect PHI. Any patient data collection must comply with applicable healthcare privacy laws and should be implemented with secure, reviewed backend services.</p>
  </section>
</MainLayout>
