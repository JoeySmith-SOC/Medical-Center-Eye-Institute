---
import MainLayout from '../layouts/MainLayout.astro'
import SectionHeader from '../components/SectionHeader.astro'

const pageTitle = 'Terms of Use'
const pageDescription = 'Terms of use placeholder.'
---
<MainLayout title={pageTitle} description={pageDescription}>
  <section class="container">
    <SectionHeader title="Terms of Use" />
    <p class="muted">These Terms of Use are a placeholder. Replace with site-specific terms and seek legal review prior to publishing.</p>
  </section>
</MainLayout>
