---
import MainLayout from '../layouts/MainLayout.astro'
import SectionHeader from '../components/SectionHeader.astro'

const pageTitle = 'Contact'
const pageDescription = 'Contact information and appointment request form (UI only).'
---
<MainLayout title={pageTitle} description={pageDescription}>
  <section class="container">
    <SectionHeader title="Contact Us" subtitle="Phone, address, and hours" />

    <div class="contact-grid">
      <div>
        <h3>Phone</h3>
        <p class="muted">(000) 000-0000 — placeholder</p>

        <h3>Address</h3>
        <address class="muted">123 Main St., City, State ZIP — placeholder</address>

        <h3>Office Hours</h3>
        <p class="muted">Mon–Fri 8:30 AM – 5:00 PM</p>
      </div>

      <div>
        <h3>Request an Appointment</h3>
        <form class="contact-form" on:submit="return false;">
          <label>
            Full name
            <input name="name" type="text" placeholder="Full name" required />
          </label>
          <label>
            Phone
            <input name="phone" type="tel" placeholder="Phone" />
          </label>
          <label>
            Email
            <input name="email" type="email" placeholder="Email" />
          </label>
          <label>
            Message (do not include medical emergencies)
            <textarea name="message" placeholder="Brief message" rows="4"></textarea>
          </label>
          <p class="muted small">Do NOT use this form for urgent or emergency medical issues. Call emergency services or the office phone.</p>
          <div>
            <button class="btn primary" type="submit">Send Request (UI only)</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</MainLayout>
